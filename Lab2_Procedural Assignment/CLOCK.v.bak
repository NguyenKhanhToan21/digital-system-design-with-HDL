module CLOCK (
	input [4:0] hour,
	input [5:0] min, sec,
	input reset, CLOCK_50,
	output [6:0] HEX0, HEX1, HEX2, HEX3, HEX4,HEX5, HEX6, HEX7
);
	reg [6:0] HEX_reg [7:0];
	reg [5:0] s_cnt, m_cnt;
   reg [4:0] h_cnt;
	clock_1s CLK (.CLOCK_50(CLOCK_50), .reset(reset), .clock1s(clock1s));
	assign is_error = (hour_in >= 5'd24) || (min_in >= 6'd60) || (sec_in >= 6'd60);
    always @(posedge clk_1s or negedge reset) begin
        if (!reset) begin
            if (!is_error) begin
                h_cnt <= hour_in;
                m_cnt <= min_in;
                s_cnt <= sec_in;
            end else begin
                h_cnt <= 5'd0;
                m_cnt <= 6'd0;
                s_cnt <= 6'd0;
            end
        end else begin
            if (s_cnt == 6'd59) begin
                s_cnt <= 6'd0;
                if (m_cnt == 6'd59) begin
                    m_cnt <= 6'd0;
                    if (h_cnt == 5'd23) h_cnt <= 5'd0;
                    else h_cnt <= h_cnt + 1'b1;
                end else m_cnt <= m_cnt + 1'b1;
            end else s_cnt <= s_cnt + 1'b1;
        end
    end
    assign HEX2 = decoder(s_cnt % 10);
    assign HEX3 = decoder(s_cnt / 10);
    assign HEX4 = decoder(m_cnt % 10);
    assign HEX5 = decoder(m_cnt / 10);
    assign HEX6 = is_error ? 7'b0000110 : decoder(h_cnt % 10);
    assign HEX7 = is_error ? 7'b0000110 : decoder(h_cnt / 10);
    assign HEX0 = 7'b1111111;
    assign HEX1 = 7'b1111111;

	decoder b1 (. BCD())

endmodule