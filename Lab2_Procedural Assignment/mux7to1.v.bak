module mux7to1 (
	input [6:0] in [6:0],
	input [2:0] sel,
	output reg [6:0] out
);
	always @(*) begin 
		case(sel) 
			3'd0 : out = in[0];
			3'd1 : out = in[1];
			3'd2 : out = in[2];
			3'd3 : out = in[3];
			3'd4 : out = in[4];
			3'd5 : out = in[5];
			3'd6 : out = in[6];
			default : out = 7'b1111111;
		endcase
	end 
endmodule

			
			