`timescale 1ns/1ps

module tb_single_port_RAM_sc;

  reg CLK;
  reg cs, wr_e, oe;
  reg [6:0] addr;

  wire [7:0] data;
  reg  [7:0] data_drv;

  // Golden memory
  reg [7:0] expected_mem [0:127];

  integer i;
  integer error_count = 0;


  // TRI-STATE CONTROL

  assign data = (cs && wr_e) ? data_drv : 8'bz;


  // DUT

  single_port_RAM uut (
    .CLK(CLK),
    .cs(cs),
    .wr_e(wr_e),
    .oe(oe),
    .addr(addr),
    .data(data)
  );


  // CLOCK

  initial CLK = 0;
  always #5 CLK = ~CLK;


  // INIT GOLDEN MEMORY

  initial begin
    for (i = 0; i < 128; i = i + 1)
      expected_mem[i] = 8'd0;
  end


  // TASK: WRITE

  task write_mem(input [6:0] a, input [7:0] d);
  begin
    @(negedge CLK);
    cs = 1;
    wr_e = 1;
    oe = 0;
    addr = a;
    data_drv = d;

    @(posedge CLK); // ghi

    // c?p nh?t golden model
    expected_mem[a] = d;
  end
  endtask


  // TASK: READ + CHECK

  task read_check(input [6:0] a);
  begin
    @(negedge CLK);
    cs = 1;
    wr_e = 0;
    oe = 1;
    addr = a;

    @(posedge CLK); 
    #1; // tránh race

    if (data !== expected_mem[a]) begin
      $display("ERROR at time %0t | addr=%0d | data=%h | expected=%h",
                $time, a, data, expected_mem[a]);
      error_count = error_count + 1;
    end else begin
      $display("OK at time %0t | addr=%0d | data=%h",
                $time, a, data);
    end
  end
  endtask


  // TEST SEQUENCE

  initial begin
    // Init
    cs = 0;
    wr_e = 0;
    oe = 0;
    addr = 0;
    data_drv = 0;

    // -------------------------
    // Test 1: Write & Read ??n
    // -------------------------
    write_mem(10, 8'hAA);
    read_check(10);

    // -------------------------
    // Test 2: Nhi?u ??a ch?
    // -------------------------
    write_mem(20, 8'h11);
    write_mem(21, 8'h22);
    write_mem(22, 8'h33);

    read_check(20);
    read_check(21);
    read_check(22);

    // -------------------------
    // Test 3: Overwrite
    // -------------------------
    write_mem(20, 8'hFF);
    read_check(20);

    // -------------------------
    // Test 4: Random test
    // -------------------------
    for (i = 0; i < 20; i = i + 1) begin
      write_mem($random % 128, $random);
    end

    for (i = 0; i < 20; i = i + 1) begin
      read_check($random % 128);
    end

    // -------------------------
    // REPORT
    // -------------------------
    if (error_count == 0)
      $display("===== ALL TEST PASSED =====");
    else
      $display("===== TEST FAILED: %0d ERRORS =====", error_count);

    #20;
    $stop;
  end

endmodule