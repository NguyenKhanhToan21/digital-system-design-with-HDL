// *****************************************************************************
// This file contains a Verilog test bench with test vectors .The test vectors  
// are exported from a vector file in the Quartus Waveform Editor and apply to  
// the top level entity of the current Quartus project .The user can use this   
// testbench to simulate his design using a third-party simulation tool .       
// *****************************************************************************
// Generated on "03/08/2026 17:17:24"
                                                                        
// Verilog Self-Checking Test Bench (with test vectors) for design :    cau3c
// 
// Simulation tool : 3rd Party
// 

`timescale 1 ps/ 1 ps
module cau3c_vlg_sample_tst(
	CLK,
	D,
	sampler_tx
);
input  CLK;
input  D;
output sampler_tx;

reg sample;
time current_time;
always @(CLK or D)
                                                                                
begin                                                 
 if ($realtime > 0)                                   
 begin                                                
	if ($realtime == 0 || $realtime != current_time)  
	begin									          
		if (sample === 1'bx)                          
			sample = 0;                               
		else                                          
			sample = ~sample;                         
	end										          
	current_time = $realtime;					      
 end                                                  
end                                                   

assign sampler_tx = sample;
endmodule

module cau3c_vlg_check_tst (
	Qa,
	Qan,
	Qb,
	Qbn,
	Qc,
	Qcn,
	sampler_rx
);
input  Qa;
input  Qan;
input  Qb;
input  Qbn;
input  Qc;
input  Qcn;
input sampler_rx;

reg  Qa_expected;
reg  Qan_expected;
reg  Qb_expected;
reg  Qbn_expected;
reg  Qc_expected;
reg  Qcn_expected;

reg  Qa_prev;
reg  Qan_prev;
reg  Qb_prev;
reg  Qbn_prev;
reg  Qc_prev;
reg  Qcn_prev;

reg  Qa_expected_prev;
reg  Qan_expected_prev;
reg  Qb_expected_prev;
reg  Qbn_expected_prev;
reg  Qc_expected_prev;
reg  Qcn_expected_prev;

reg  last_Qa_exp;
reg  last_Qan_exp;
reg  last_Qb_exp;
reg  last_Qbn_exp;
reg  last_Qc_exp;
reg  last_Qcn_exp;

reg trigger;

integer i;
integer nummismatches;

reg [1:6] on_first_change ;


initial
begin
trigger = 0;
i = 0;
nummismatches = 0;
on_first_change = 6'b1;
end

// update real /o prevs

always @(trigger)
begin
	Qa_prev = Qa;
	Qan_prev = Qan;
	Qb_prev = Qb;
	Qbn_prev = Qbn;
	Qc_prev = Qc;
	Qcn_prev = Qcn;
end

// update expected /o prevs

always @(trigger)
begin
	Qa_expected_prev = Qa_expected;
	Qan_expected_prev = Qan_expected;
	Qb_expected_prev = Qb_expected;
	Qbn_expected_prev = Qbn_expected;
	Qc_expected_prev = Qc_expected;
	Qcn_expected_prev = Qcn_expected;
end



// expected Qa
initial
begin
	Qa_expected = 1'bX;
end 

// expected Qan
initial
begin
	Qan_expected = 1'bX;
end 

// expected Qb
initial
begin
	Qb_expected = 1'bX;
end 

// expected Qbn
initial
begin
	Qbn_expected = 1'bX;
end 

// expected Qc
initial
begin
	Qc_expected = 1'bX;
end 

// expected Qcn
initial
begin
	Qcn_expected = 1'bX;
end 
// generate trigger
always @(Qa_expected or Qa or Qan_expected or Qan or Qb_expected or Qb or Qbn_expected or Qbn or Qc_expected or Qc or Qcn_expected or Qcn)
begin
	trigger <= ~trigger;
end

always @(posedge sampler_rx or negedge sampler_rx)
begin
`ifdef debug_tbench
	$display("Scanning pattern %d @time = %t",i,$realtime );
	i = i + 1;
	$display("| expected Qa = %b | expected Qan = %b | expected Qb = %b | expected Qbn = %b | expected Qc = %b | expected Qcn = %b | ",Qa_expected_prev,Qan_expected_prev,Qb_expected_prev,Qbn_expected_prev,Qc_expected_prev,Qcn_expected_prev);
	$display("| real Qa = %b | real Qan = %b | real Qb = %b | real Qbn = %b | real Qc = %b | real Qcn = %b | ",Qa_prev,Qan_prev,Qb_prev,Qbn_prev,Qc_prev,Qcn_prev);
`endif
	if (
		( Qa_expected_prev !== 1'bx ) && ( Qa_prev !== Qa_expected_prev )
		&& ((Qa_expected_prev !== last_Qa_exp) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Qa :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qa_expected_prev);
		$display ("     Real value = %b", Qa_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_Qa_exp = Qa_expected_prev;
	end
	if (
		( Qan_expected_prev !== 1'bx ) && ( Qan_prev !== Qan_expected_prev )
		&& ((Qan_expected_prev !== last_Qan_exp) ||
			on_first_change[2])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Qan :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qan_expected_prev);
		$display ("     Real value = %b", Qan_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_Qan_exp = Qan_expected_prev;
	end
	if (
		( Qb_expected_prev !== 1'bx ) && ( Qb_prev !== Qb_expected_prev )
		&& ((Qb_expected_prev !== last_Qb_exp) ||
			on_first_change[3])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Qb :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qb_expected_prev);
		$display ("     Real value = %b", Qb_prev);
		nummismatches = nummismatches + 1;
		on_first_change[3] = 1'b0;
		last_Qb_exp = Qb_expected_prev;
	end
	if (
		( Qbn_expected_prev !== 1'bx ) && ( Qbn_prev !== Qbn_expected_prev )
		&& ((Qbn_expected_prev !== last_Qbn_exp) ||
			on_first_change[4])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Qbn :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qbn_expected_prev);
		$display ("     Real value = %b", Qbn_prev);
		nummismatches = nummismatches + 1;
		on_first_change[4] = 1'b0;
		last_Qbn_exp = Qbn_expected_prev;
	end
	if (
		( Qc_expected_prev !== 1'bx ) && ( Qc_prev !== Qc_expected_prev )
		&& ((Qc_expected_prev !== last_Qc_exp) ||
			on_first_change[5])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Qc :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qc_expected_prev);
		$display ("     Real value = %b", Qc_prev);
		nummismatches = nummismatches + 1;
		on_first_change[5] = 1'b0;
		last_Qc_exp = Qc_expected_prev;
	end
	if (
		( Qcn_expected_prev !== 1'bx ) && ( Qcn_prev !== Qcn_expected_prev )
		&& ((Qcn_expected_prev !== last_Qcn_exp) ||
			on_first_change[6])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Qcn :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qcn_expected_prev);
		$display ("     Real value = %b", Qcn_prev);
		nummismatches = nummismatches + 1;
		on_first_change[6] = 1'b0;
		last_Qcn_exp = Qcn_expected_prev;
	end

	trigger <= ~trigger;
end
initial 

begin 
$timeformat(-12,3," ps",6);
#1000000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module cau3c_vlg_vec_tst();
// constants                                           
// general purpose registers
reg CLK;
reg D;
// wires                                               
wire Qa;
wire Qan;
wire Qb;
wire Qbn;
wire Qc;
wire Qcn;

wire sampler;                             

// assign statements (if any)                          
cau3c i1 (
// port map - connection between master ports and signals/registers   
	.CLK(CLK),
	.D(D),
	.Qa(Qa),
	.Qan(Qan),
	.Qb(Qb),
	.Qbn(Qbn),
	.Qc(Qc),
	.Qcn(Qcn)
);

// CLK
always
begin
	CLK = 1'b0;
	CLK = #10000 1'b1;
	#10000;
end 

// D
initial
begin
	D = 1'b1;
	D = #10000 1'b0;
	D = #10000 1'b1;
	D = #40000 1'b0;
	D = #10000 1'b1;
	D = #10000 1'b0;
	D = #20000 1'b1;
	D = #10000 1'b0;
	D = #10000 1'b1;
	D = #40000 1'b0;
	D = #10000 1'b1;
	D = #10000 1'b0;
	D = #10000 1'b1;
	D = #30000 1'b0;
	D = #10000 1'b1;
	D = #20000 1'b0;
	D = #10000 1'b1;
	D = #40000 1'b0;
	D = #40000 1'b1;
	D = #20000 1'b0;
	D = #20000 1'b1;
	D = #30000 1'b0;
	D = #10000 1'b1;
	D = #10000 1'b0;
	D = #10000 1'b1;
	D = #10000 1'b0;
	D = #10000 1'b1;
	D = #10000 1'b0;
	D = #10000 1'b1;
	D = #10000 1'b0;
	D = #20000 1'b1;
	D = #20000 1'b0;
	D = #10000 1'b1;
	D = #10000 1'b0;
	D = #40000 1'b1;
	D = #90000 1'b0;
	D = #10000 1'b1;
	D = #40000 1'b0;
	D = #100000 1'b1;
	D = #10000 1'b0;
	D = #10000 1'b1;
	D = #50000 1'b0;
	D = #10000 1'b1;
	D = #10000 1'b0;
	D = #10000 1'b1;
	D = #30000 1'b0;
	D = #10000 1'b1;
end 

cau3c_vlg_sample_tst tb_sample (
	.CLK(CLK),
	.D(D),
	.sampler_tx(sampler)
);

cau3c_vlg_check_tst tb_out(
	.Qa(Qa),
	.Qan(Qan),
	.Qb(Qb),
	.Qbn(Qbn),
	.Qc(Qc),
	.Qcn(Qcn),
	.sampler_rx(sampler)
);
endmodule

